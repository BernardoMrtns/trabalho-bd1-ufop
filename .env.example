# ==========================================
# Configurações do Banco de Dados PostgreSQL
# ==========================================

# Host e Porta padrão do PostgreSQL
DB_HOST=localhost
DB_PORT=5432

# Nome do banco de dados criado na etapa 4 (Scripts SQL)
DB_NAME=nome_do_seu_banco_aqui

# Credenciais de acesso padrão (alterar se necessário)
DB_USER=postgres
DB_PASSWORD=postgres

# ==========================================
# NOTA PARA O AVALIADOR:
# Renomeie este arquivo para ".env" e 
# preencha com as credenciais do seu SGBD local.
# ==========================================